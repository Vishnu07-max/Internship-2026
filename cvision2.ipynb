    "import cv2\n",
    "print(cv2.__version__)\n",
    "from ultralytics import YOLO\n",
    "model = YOLO(\"yolov8n.pt\")\n",
    "predict_class=[0,14]\n",
    "img='./lio2.jpg'\n",
    "pred=model(img,classes=predict_class,conf=.4)\n",
    "pred_img=pred(0).draw()\n",
